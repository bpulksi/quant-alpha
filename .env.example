# ─── Alpaca API ───────────────────────────────────────────────────────────────
# Get from: alpaca.markets → Paper Trading → API Keys
# Paper URL: https://paper-api.alpaca.markets
# Live URL:  https://api.alpaca.markets
ALPACA_API_KEY=your_alpaca_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_here

# ─── Trading mode ─────────────────────────────────────────────────────────────
TRADE_MODE=spot

# ─── Paper vs Live ────────────────────────────────────────────────────────────
# true  = paper trading (safe, no real money) ← START HERE
# false = LIVE trading  (real money — only flip after 4 weeks profitable paper)
PAPER_TRADING=true

# ─── Portfolio size ───────────────────────────────────────────────────────────
# Paper mode:  100000  (simulated capital)
# Live mode:   set to your actual Alpaca balance (e.g. 180 after 3 months saving)
PORTFOLIO_VALUE_USD=100000

# ─── Trade size limits ────────────────────────────────────────────────────────
# Paper mode:  8000 per trade (test signals at scale)
# Live mode:   25 per trade  (€60/mo budget — change when you flip PAPER_TRADING=false)
MAX_TRADE_SIZE_USD=8000
MAX_TRADES_PER_DAY=10

# ─── Assets to scan ───────────────────────────────────────────────────────────
# Crypto (Alpaca-tradeable)
SYMBOL=BTCUSDT,ETHUSDT,SOLUSDT,XRPUSDT,AVAXUSDT,ADAUSDT,DOTUSDT,LINKUSDT,LTCUSDT,DOGEUSDT,BNBUSDT,SUIUSDT,UNIUSDT,XLMUSDT,ATOMUSDT,TRXUSDT,INJUSDT,RENDERUSDT,TAOUSDT,FILUSDT

# Stocks + ETFs
STOCK_SYMBOLS=AAPL,MSFT,NVDA,GOOGL,META,AMZN,TSLA,AMD,PLTR,CRM,ORCL,SNOW,COIN,MSTR,SOFI,JPM,V,MA,GS,LLY,UNH,JNJ,MRNA,XOM,CVX,WMT,COST,MCD,SPY,QQQ,IWM,GLD,TLT,XLE,XLF,XLV

TIMEFRAME=15

# ─── Telegram ─────────────────────────────────────────────────────────────────
# 1. Message @BotFather → /newbot → copy the token
# 2. Message @userinfobot → copy your chat ID
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ─── Research agent (optional) ────────────────────────────────────────────────
CRYPTOPANIC_TOKEN=           # free at cryptopanic.com/developers/api/
REDDIT_CLIENT_ID=            # free at reddit.com/prefs/apps (script type)
REDDIT_CLIENT_SECRET=
ENABLE_RESEARCH=false        # set true after testing
OLLAMA_MODEL=llama3.2:3b    # local LLM for news sentiment

# ─── SIP system (Scott Galloway 80/20 formula) ────────────────────────────────
# Monthly budget: €300
#   80% = €240 → SIP retirement (VTI €100, SCHD €60, VXUS €50, BTC €30)
#   20% = €60  → Trading bot capital (save 3 months → €180 → go live)
#
# Go-live checklist:
#   [ ] 4 weeks profitable paper trading
#   [ ] €180+ saved in Alpaca live account
#   [ ] Set PAPER_TRADING=false
#   [ ] Set MAX_TRADE_SIZE_USD=25
#   [ ] Set PORTFOLIO_VALUE_USD=180
